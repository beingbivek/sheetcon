// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ADMIN MODEL
// ═══════════════════════════════════════════════════

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ADMIN)

  isActive  Boolean   @default(true)
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ═══════════════════════════════════════════════════
// TIER MODEL (Subscription Plans)
// ═══════════════════════════════════════════════════

model Tier {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?

  price    Float  @default(0)
  currency String @default("INR")

  maxUsers         Int @default(-1)
  currentUserCount Int @default(0)
  maxSheets        Int @default(1)
  maxTemplates     Int @default(1)
  maxCrudPerDay    Int @default(1000)

  customBranding  Boolean @default(false)
  prioritySupport Boolean @default(false)
  exportToPdf     Boolean @default(true)

  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([slug])
}

// ═══════════════════════════════════════════════════
// USER MODEL (UPDATED with token fields)
// ═══════════════════════════════════════════════════

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  image        String?
  passwordHash String?

  // Tier relation
  tierId String
  tier   Tier   @relation(fields: [tierId], references: [id])

  // OAuth tokens - UPDATED
  googleId       String?   @unique
  accessToken    String?   @db.Text
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime? // NEW

  // Status
  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  // Ban system
  isBanned  Boolean @default(false)
  banReason String?

  // Activity tracking
  lastLoginAt DateTime?

  // Usage tracking - UPDATED field name
  crudCountToday  Int      @default(0)
  lastCrudResetAt DateTime @default(now()) // Renamed from lastCrudReset

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sheetConnections SheetConnection[]

  @@index([email])
  @@index([tierId])
  @@index([googleId])
}

// ═══════════════════════════════════════════════════
// SHEET OPERATION MODEL (NEW)
// ═══════════════════════════════════════════════════

model SheetOperation {
  id           String  @id @default(cuid())
  userId       String
  sheetId      String
  operation    String // READ, WRITE, UPDATE, DELETE
  rowsAffected Int     @default(0)
  success      Boolean
  errorMessage String? @db.Text

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sheetId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════
// SHEET CONNECTION MODEL (UPDATED)
// ═══════════════════════════════════════════════════

model SheetConnection {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sheet Details - UPDATED
  sheetType       String // FINANCE, INVENTORY, etc.
  spreadsheetId   String
  spreadsheetName String
  spreadsheetUrl  String? // NEW
  sheetName       String? // NEW - specific tab name (e.g., "Sheet1")

  // Template - UPDATED with relation
  templateId     String?
  template       Template? @relation(fields: [templateId], references: [id]) // NEW RELATION
  templateLocked Boolean   @default(false)
  lockedAt       DateTime?

  // Column Mappings
  columnMappings Json?

  // Status - UPDATED
  isActive         Boolean   @default(true)
  lastSyncAt       DateTime? // Renamed from lastSyncedAt
  syncStatus       String    @default("PENDING")
  syncErrorMessage String?   // Renamed from syncError

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, spreadsheetId])
  @@index([userId, isActive])
  @@index([templateId])
  @@index([spreadsheetId])
}

// ═══════════════════════════════════════════════════
// TEMPLATE MODEL (UPDATED to support relation)
// ═══════════════════════════════════════════════════

model Template {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text
  icon        String  @default("📋")

  // Template Configuration (JSON Schema)
  configSchema Json

  // UI Configuration
  primaryColor String @default("#3b82f6")

  // Features enabled for this template
  features String[] @default([])

  // Availability
  isActive Boolean @default(true)
  isPublic Boolean @default(true)

  // Version control
  version String @default("1.0.0")

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - NEW
  sheetConnections SheetConnection[]

  @@index([slug])
  @@index([isActive, isPublic])
}