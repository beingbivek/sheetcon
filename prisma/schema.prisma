// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ADMIN MODEL
// ═══════════════════════════════════════════════════

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ADMIN)
  
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  @@index([email])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ═══════════════════════════════════════════════════
// TIER MODEL (Subscription Plans)
// ═══════════════════════════════════════════════════

model Tier {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  
  price       Float    @default(0)
  currency    String   @default("INR")
  
  maxUsers          Int      @default(-1)
  currentUserCount  Int      @default(0)
  maxSheets         Int      @default(1)
  maxTemplates      Int      @default(1)
  maxCrudPerDay     Int      @default(1000)
  
  customBranding    Boolean  @default(false)
  prioritySupport   Boolean  @default(false)
  exportToPdf       Boolean  @default(true)
  
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  
  @@index([slug])
}

// ═══════════════════════════════════════════════════
// USER MODEL (Updated)
// ═══════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  
  // Tier relation
  tierId        String
  tier          Tier      @relation(fields: [tierId], references: [id])
  
  // OAuth tokens
  googleId      String?   @unique
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  
  // Status
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  
  // Ban system (NEW FIELDS)
  isBanned      Boolean   @default(false)
  banReason     String?
  
  // Activity tracking
  lastLoginAt   DateTime?
  
  // Usage tracking
  crudCountToday    Int      @default(0)
  lastCrudReset     DateTime @default(now())
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  sheetConnections SheetConnection[]
  
  @@index([email])
  @@index([tierId])
}

// ═══════════════════════════════════════════════════
// SHEET CONNECTION MODEL (Add if not exists)
// ═══════════════════════════════════════════════════

model SheetConnection {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Sheet Details
  sheetType       String    // "google_sheets", "excel_online"
  spreadsheetId   String
  spreadsheetName String
  spreadsheetUrl  String
  
  // Template Lock
  templateId      String?
  templateLocked  Boolean   @default(false)
  lockedAt        DateTime?
  
  // Column Mappings
  columnMappings  Json?
  
  // Status
  isActive        Boolean   @default(true)
  lastSyncedAt    DateTime?
  syncStatus      String    @default("PENDING")
  syncError       String?
  
  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([userId, spreadsheetId])
  @@index([userId, isActive])
}